  <experiments>
    <experiment name="time-to-spread-simple" repetitions="100" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="300">
      <setup>generate-topology
infect-two</setup>
      <go>spread</go>
      <exitCondition><![CDATA[rewiring-probability > 1]]></exitCondition>
      <metrics>
        <metric>ticks</metric>
        <metric>pct-infected</metric>
