<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[breed [recipients recipient]
breed [disseminators disseminator]

undirected-link-breed [usuals usual]
directed-link-breed [initiates initiate]

globals
[
  num-infected ;; how many agents are believer?
  infected-size ;;the size of the infected agents
  num-dis ;;number of disseminators
]

turtles-own
[
  believer?
]

recipients-own
[
  susceptible
  reinforce
  resisted
]

disseminators-own
[
  persuasive
]

to setup
  clear-all
  set infected-size 5
  set-default-shape turtles "outlined circle"
  make-turtles ;;create agents
  estab-dis ;;create disseminators
  wire-lattice ;;arrange them in a ring lattice
  rewire-network ;;apply the small-world algorithm
  wire-dis ;;create directed edges only for disseminators
  vary-susceptibility  ;;each node will have its own probability of accepting info as true
  reset-ticks
end

to make-turtles
  create-turtles num-nodes [ reset-node ]
  ;; arrange turtles in an ordered, staggered circle
  layout-circle (sort turtles) max-pxcor - 8
  ;; space out turtles to see clustering
  ask turtles
  [
    facexy 0 0
    if who mod 2 = 0 [fd 10]
    set breed recipients
  ]
end

to estab-dis
  ask turtles [ reset-node ]
  set num-dis num-nodes / 100
  let n 1
  while [n <= num-dis]
   [
    ask one-of turtles [
      set believer? true
      set breed disseminators
      set color red
      set size infected-size
      set persuasive random-float 1 + .5 
      ]
    set n n + 1  
      
  ]   
  set num-infected count turtles with [believer?]
end

;; creates the links for the ring lattice
to wire-lattice
  let degree 4 ;;assert degree 4. This can be modified for arbitrary degree
  ;; iterate over the nodes
  ask recipients [
    set susceptible 0
    create-usuals-with min-n-of degree other recipients [distance myself] [ set color gray + 1.5]
     ]
end


;; Rewire the network connections
;; WARNING: the simplified rewiring algorithm does not ensure that the network will be completely connected
;; for large networks this shouldn't be too much of an issue.
to rewire-network
  ask usuals
  [
    if (random-float 1) < rewiring-probability
    [
      ask end1
      [
        create-usual-with one-of other recipients with [not link-neighbor? myself ]
          [set color gray + 1.5]
      ]
      die
    ]
  ]
end

to wire-dis
  let dis-degree 6
  ask disseminators [
    create-initiates-to n-of dis-degree recipients [set color red]
  ]     
end    

;;set the susceptibility of the turtles as a uniform distribution
to vary-susceptibility
  ask recipients [
    set susceptible random-float 1
    set reinforce random-float 1
  ]
end 



to reset-node
    set color gray + 1.5
    set size 4
    set believer? false
end




to go
  if all? turtles [believer?] [ stop ]
  
   ;; directed dissemination from special source agents
  ask disseminators [
    ask link-neighbors with [not believer?] [
      if random-float 1 <= susceptible * [persuasive] of myself [
        set believer? true
        set color yellow
        set size infected-size
      ]
    ]
  ]

  ;; normal social diffusion through undirected network
  ask recipients with [believer?] [
    ask link-neighbors with [not believer?] [
      ifelse random-float 1 <= susceptible * [reinforce] of myself
      [
        set believer? true
        set color yellow
        set size infected-size
      ]
      [
        set susceptible susceptible * .85
      ]
    ]
  ]

 

  set num-infected count turtles with [believer?]
  tick
end



























]]></code>
  <widgets>
    <view x="302" wrappingAllowedX="false" y="10" frameRate="30.0" minPycor="-80" height="478" showTickCounter="true" patchSize="2.9441" fontSize="10" wrappingAllowedY="false" width="478" tickCounterLabel="ticks" maxPycor="80" updateMode="1" maxPxcor="80" minPxcor="-80"></view>
    <slider x="9" step="1" y="146" max="2000" display="num-nodes" height="50" min="10" direction="Horizontal" default="500.0" variable="num-nodes" width="180" sizeVersion="0"></slider>
    <slider x="8" step="0.001" y="201" max="1" display="rewiring-probability" height="50" min="0" direction="Horizontal" default="0.078" variable="rewiring-probability" width="181" sizeVersion="0"></slider>
    <plot x="8" autoPlotX="true" yMax="1.0" autoPlotY="true" yAxis=" infected" y="314" xMin="0.0" height="194" legend="false" xMax="1.0" yMin="0.0" xAxis="time" display="proportion infected" width="277" sizeVersion="0">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="inf" color="-2674135" legend="true">
        <setup></setup>
        <update>plot (num-infected ) / (count turtles)</update>
      </pen>
    </plot>
    <button x="10" y="55" height="40" disableUntilTicks="false" forever="true" kind="Observer" display="go" width="121" sizeVersion="0">go</button>
    <monitor x="194" precision="17" y="176" height="60" fontSize="11" width="100" sizeVersion="0">num-infected</monitor>
    <button x="10" y="10" height="40" disableUntilTicks="false" forever="false" kind="Observer" display="setup" width="121" sizeVersion="0">setup</button>
    <switch x="11" y="101" height="40" on="false" variable="complex-contagion?" display="complex-contagion?" width="179" sizeVersion="0"></switch>
  </widgets>
  <info>## Model Information and Materials

This model is original material created by Paul E. Smaldino, building on work by Centola and Macy (2007). 

* Centola D, Macy M (2007) Complex contagions and the weakness of long ties. American Journal of Sociology 113: 702-734.

## References and Citation

For this model:

* Smaldino PE (2023). Small World Diffusion. Modeling Social Behavior.  https://github.com/psmaldino/modsoc/

For the book:

* Smaldino PE (2023). Modeling Social Behavior: Mathematical and Agent-Based Models of Social Dynamics and Cultural Evolution. Princeton University Press. 

For the NetLogo:

* Wilensky, U. (1999). NetLogo. http://ccl.northwestern.edu/netlogo/. Center for Connected Learning and Computer-Based Modeling, Northwestern University, Evanston, IL.


